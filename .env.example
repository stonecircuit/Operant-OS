# =========================================================================
# Operant OS - Production Environment Variables Example Template
# Rename this file to '.env.local' or configure these values in your hosting
# provider (e.g. Vercel environment settings, Cloudflare pages).
# Do NOT commit raw production credentials to version control.
# =========================================================================

# -------------------------------------------------------------------------
# Server-side Environment Configurations (Secure API Keys)
# -------------------------------------------------------------------------

# Google Generative AI / Gemini API Key
# Used for natural language transactions routing, P&L reporting insights, 
# financial copilot interactions, and receipt intelligence extraction.
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# Client-side Environment Configurations (Public Firebase Settings)
# Prefix 'NEXT_PUBLIC_' makes these keys accessible within the browser.
# -------------------------------------------------------------------------

# Firebase Client API Key
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase Authentication Domain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# Firebase Project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here

# Firebase Storage Bucket URL
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app

# Firebase Cloud Messaging Sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here

# Firebase Web App ID
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash_here
